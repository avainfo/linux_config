#!/usr/bin/env bash

OS="$(uname -s)"

if [ "$OS" = "Darwin" ]; then
    # macOS : éviter la logique tmux fragile qui fait crasher kitty
    exec zsh -l
fi

# Linux : garder ton comportement actuel
SESSION_COUNT="$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')"
exec zsh -lc "tmux new-session -s tmux${SESSION_COUNT}"
